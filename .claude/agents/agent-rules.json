          "optimize",
          "optimization",
          "slow",
          "speed",
          "fast",
          "Core Web Vitals",
          "LCP",
          "CLS",
          "INP",
          "Lighthouse",
          "bundle size",
          "lazy loading",
          "caching",
          "memory",
          "CPU",
          "bottleneck",
          "profiling",
          "performance review",
          "PageSpeed"
        ],
        "intentPatterns": [
          "(optimize|improve).*?(performance|speed|loading)",
          "(slow|sluggish|laggy).*?(page|app|component|query)",
          "(Core Web Vitals|Lighthouse|PageSpeed).*?(score|improvement|optimization)",
          "(reduce|minimize).*?(bundle|size|load time|latency)",
          "(database|query).*?(optimization|performance|slow)",
          "(memory|CPU).*?(usage|leak|optimization)",
          "(profile|analyze).*?(performance|bottleneck)",
          "(use|spawn|invoke).*?performance.*?(agent|optimizer)"
        ]
      }
    },
    "quality-engineer": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Proactive quality enforcement, testing strategies, TDD, pattern validation, and focused test coverage",
      "promptTriggers": {
        "keywords": [
          "test",
          "testing",
          "TDD",
          "unit test",
          "integration test",
          "E2E",
          "end-to-end",
          "pytest",
          "Vitest",
          "Playwright",
          "coverage",
          "quality",
          "QA",
          "assertion",
          "mock",
          "stub",
          "fixture",
          "verify",
          "validate"
        ],
        "intentPatterns": [
          "(write|create|add).*?(test|tests|testing)",
          "(unit|integration|E2E|end-to-end).*?(test|testing)",
          "(test|testing).*?(coverage|strategy|approach)",
          "(TDD|test-driven).*?(development|approach)",
          "(quality|QA).*?(enforcement|assurance|validation)",
          "(pytest|Vitest|Playwright).*?(test|setup|configuration)",
          "(verify|validate).*?(implementation|behavior|functionality)"
        ]
      }
    },
    "security-auditor": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "high",
