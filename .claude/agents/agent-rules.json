          "vulnerability",
          "audit",
          "OWASP",
          "XSS",
          "SQL injection",
          "CSRF",
          "authentication security",
          "authorization",
          "encryption",
          "hashing",
          "secrets",
          "penetration",
          "pentest",
          "credentials",
          "expose",
          "sensitive",
          "JWT"
        ],
        "intentPatterns": [
          "(security|vulnerability).*?(audit|review|assessment)",
          "(check|validate|verify).*?(security|authorization)",
          "(OWASP|XSS|SQL injection|CSRF).*?(compliance|prevention|check)",
          "(secure|harden).*?(application|API|endpoint|database)",
          "(authentication|authorization).*?(security|validation|audit)",
          "(credentials|secrets).*?(expose|leak|protection)"
