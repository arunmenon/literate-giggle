    "code-simplifier": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Code simplification and refactoring for clarity while preserving functionality",
      "promptTriggers": {
        "keywords": [
          "simplify",
          "refactor",
          "clean up",
          "readable",
          "readability",
          "complexity",
          "simplification",
          "code quality",
          "code smell",
          "DRY",
          "SOLID",
          "reduce complexity"
        ],
        "intentPatterns": [
          "(simplify|refactor|clean up).*?(code|function|component|module)",
          "(improve|increase).*?(readability|clarity|maintainability)",
          "(reduce|eliminate).*?(complexity|duplication|nesting)",
          "(code|function).*?(smell|quality|review)"
        ]
      }
    },
    "session-librarian": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "low",
      "description": "Session file organization, consolidation, and cleanup in .claude/tasks/",
      "promptTriggers": {
        "keywords": [
          "session file",
          "session cleanup",
          "session organization",
          "consolidate sessions",
          "archive session",
          "tasks folder",
          "session management",
          "clean up sessions",
          "organize sessions",
          "conclude the session",
          "new session"
        ],
        "intentPatterns": [
          "(clean up|organize|consolidate).*?session",
          "(session|tasks).*?(file|folder|cleanup|organization)",
          "(archive|move).*?session",
          "(conclude|finish|end).*?(current|this).*?session",
          "start.*?new.*?session"
        ]
      }
    },
    "visual-explainer": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "HTML visualization generation for plans, diffs, project recaps, architecture diagrams, and data tables",
      "promptTriggers": {
        "keywords": [
          "visualize",
          "visualization",
          "visual",
          "diagram",
          "architecture diagram",
          "flowchart",
          "sequence diagram",
          "data flow",
          "ER diagram",
          "state machine",
          "data table",
          "timeline",
          "plan review",
          "diff review",
          "project recap",
          "HTML diagram",
          "mermaid",
          "render as HTML",
          "comparison table",
          "view plan"
        ],
        "intentPatterns": [
          "(visualize|diagram|draw|render|illustrate).*?(architecture|system|flow|pipeline|schema|plan)",
          "(generate|create|make).*?(diagram|visualization|flowchart|chart|HTML)",
          "(review|visualize|view).*?(plan|diff|changes|implementation)",
          "(comparison|audit|matrix|report).*?(table|view|visual)"
        ]
      }
    }
  },
  "notes": {
    "enforcement_types": {
      "suggest": "Agent suggestion appears but doesn't block execution",
      "block": "Requires agent to be used before proceeding (guardrail)",
      "warn": "Shows warning but allows proceeding"
    },
    "priority_levels": {
      "critical": "Highest - Always trigger when matched (e.g., master-orchestrator for complex planning)",
      "high": "Important - Trigger for most matches (e.g., frontend, backend, testing, security)",
      "medium": "Moderate - Trigger for clear matches (e.g., research, simplification)",
      "low": "Optional - Trigger only for explicit matches (e.g., session-librarian)"
    },
    "agent_overview": {
      "backend-engineer": "FastAPI routes, SQLAlchemy models, Pydantic schemas, async endpoints",
      "code-simplifier": "Code simplification, refactoring, readability improvements",
      "debugger-detective": "Systematic debugging, root cause analysis, error investigation",
      "deep-researcher": "External internet research, technology evaluation, best practices comparison",
      "frontend-specialist": "React components, UI, forms, responsive design, state management",
      "master-orchestrator": "Strategic planning, phase management, task enrichment, codebase analysis",
      "performance-optimizer": "Performance analysis, Core Web Vitals, query optimization",
      "quality-engineer": "Testing strategies, TDD, pattern validation, quality enforcement",
      "security-auditor": "Security reviews, vulnerability assessment, OWASP compliance",
      "session-librarian": "Session file organization, consolidation, archiving",
      "visual-explainer": "HTML visualizations - architecture diagrams, data tables, plan reviews"
    }
  }
}
