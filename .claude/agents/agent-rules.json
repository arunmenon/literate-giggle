{
  "version": "1.0",
  "description": "Agent activation triggers for ExamIQ project. Controls when agents are recommended for specific tasks.",
  "agents": {
    "backend-engineer": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "high",
      "description": "FastAPI routes, SQLAlchemy models, API development, and backend architecture",
      "promptTriggers": {
        "keywords": [
          "API",
          "API route",
          "endpoint",
          "database",
          "backend",
          "middleware",
          "authentication",
          "authorization",
          "data model",
          "schema",
          "CRUD",
          "REST",
          "query",
          "server-side",
          "FastAPI",
          "SQLAlchemy",
          "Pydantic",
          "uvicorn",
          "async",
          "migration",
          "seed data",
          "evaluation engine",
          "Docker"
        ],
        "intentPatterns": [
          "(create|build|implement).*?(API|endpoint|route)",
          "(server|backend).*?(action|logic|operation)",
          "(database|data).*?(operation|query|model|schema)",
          "(implement|setup|configure).*?(authentication|authorization|middleware)",
          "(FastAPI|SQLAlchemy|Pydantic).*?(model|schema|route)",
          "(API|endpoint).*?(key|validation)",
          "(docker|database).*?(setup|configure|container)"
        ]
      }
    },
    "debugger-detective": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Systematic debugging, root cause analysis, and solving persistent technical issues",
      "promptTriggers": {
        "keywords": [
          "debug",
          "debugging",
          "bug",
          "error",
          "issue",
          "problem",
          "crash",
          "not working",
          "broken",
          "fix",
          "fix this",
          "root cause",
          "investigate",
          "trace",
          "stack trace",
          "exception",
          "failure",
          "intermittent",
          "flaky",
          "reproduce",
          "symptoms",
          "Internal Server Error",
          "500 error",
          "401",
          "404",
          "undefined",
          "null",
          "why is"
        ],
        "intentPatterns": [
          "(debug|investigate|trace).*?(error|bug|issue|problem)",
          "(find|identify).*?(root cause|issue|bug|problem)",
          "(why|how).*?(not working|failing|broken|crashing)",
          "(intermittent|flaky|random).*?(bug|error|failure)",
          "(can't|cannot).*?(reproduce|find|fix)",
          "(crash|error|exception).*?(in production|randomly|sometimes)",
          "fix this.*?(error|issue|bug)",
          "Internal Server Error",
          "what.*?(went wrong|is broken|is failing)"
        ]
      }
    },
    "deep-researcher": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "External internet research for technology evaluation, best practices, and online documentation analysis",
      "promptTriggers": {
        "keywords": [
          "research",
          "web search",
          "internet research",
          "documentation",
          "best practices",
          "compare",
          "comparison",
          "evaluate",
          "technology",
          "library",
          "framework",
          "current",
          "latest",
          "trends",
          "industry",
          "standard",
          "pros and cons",
          "study",
          "look at how"
        ],
        "intentPatterns": [
          "(research|find|search).*?(best practices|documentation|library)",
          "(compare|evaluate).*?(technology|library|framework|tool)",
          "(what are|what is).*?(best|recommended|current).*?(practice|approach)",
          "(online|web|internet).*?(research|search|documentation)",
          "(latest|current).*?(trends|practices|standards)",
          "pros.*?cons",
          "(look at|study).*?how.*?(does|works|implements)",
          "(send|dispatch).*?(researcher|research agent)"
        ]
      }
    },
    "frontend-specialist": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "high",
      "description": "React components, UI implementation, forms, responsive design, and frontend architecture",
      "promptTriggers": {
        "keywords": [
          "React",
          "component",
          "UI",
          "frontend",
          "form",
          "validation",
          "responsive",
          "CSS",
          "styling",
          "layout",
          "animation",
          "state management",
          "hook",
          "useEffect",
          "useState",
          "context",
          "button",
          "tabs",
          "sidebar",
          "modal",
          "dropdown",
          "page",
          "section",
          "dashboard",
          "heading",
          "spacing",
          "Vite",
          "TypeScript"
        ],
        "intentPatterns": [
          "(build|create|implement).*?(component|UI|frontend|form|page|section)",
          "(React|frontend).*?(component|page|layout|hook)",
          "(form|validation).*?(component|implementation|handling)",
          "(responsive|mobile).*?(design|layout|component)",
          "(state|data).*?(management|flow|handling).*?(React|frontend)",
          "(style|CSS).*?(component|layout|design)",
          "(add|remove|change).*?(button|tab|section)",
          "(spawn|invoke).*?frontend.*?specialist"
        ]
      }
    },
    "master-orchestrator": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "critical",
      "description": "Comprehensive codebase analysis, strategic planning, and technical task enrichment for complex multi-step tasks",
      "promptTriggers": {
        "keywords": [
          "plan",
          "planning",
          "strategy",
          "strategic",
          "architecture",
          "orchestrate",
          "coordinate",
          "complex task",
          "multi-step",
          "multi-phase",
          "breakdown",
          "analyze codebase",
          "implementation plan",
          "technical plan",
          "roadmap",
          "sprint",
          "phase",
          "Phase 1",
          "Phase 2",
          "Phase 3",
          "master orchestrator",
          "master-orchestrator",
          "plan it out",
          "planned out",
          "next steps",
          "batch of work"
        ],
        "intentPatterns": [
          "(plan|design).*?(implementation|architecture|feature)",
          "(complex|multi-step|multi-phase).*?(task|implementation|feature)",
          "(break down|breakdown|decompose).*?(task|feature|requirement)",
          "(strategic|comprehensive).*?(analysis|planning|approach)",
          "(coordinate|orchestrate).*?(agents|specialists|work)",
          "(codebase|architecture).*?(analysis|assessment|planning)",
          "(request|invoke|launch).*?master.*?orchestrator",
          "Phase.*?(planning|implementation|execution)",
          "let's start.*?(discussing|planning|with)",
          "(next|upcoming).*?(steps|phase|batch|work)"
        ]
      }
    },
    "performance-optimizer": {
      "type": "agent",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Performance analysis, optimization strategies, Core Web Vitals improvement, and database query optimization",
      "promptTriggers": {
