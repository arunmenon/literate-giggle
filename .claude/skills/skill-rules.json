    "session-management": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "critical",
      "description": "Complete session-based development workflow for implementation tasks. Supports 6 session types: Development, Debugging, Migration, Review, TDD, Research.",
      "promptTriggers": {
        "keywords": [
          "feature",
          "implement",
          "build",
          "create",
          "add feature",
          "bug fix",
          "refactor",
          "refactoring",
          "multi-step",
          "complex task",
          "development workflow",
          "session",
          "implementation",
          "debugging session",
          "migration",
          "code review",
          "tdd",
          "test-driven",
          "research session",
          "investigation",
          "task breakdown",
          "phase",
          "planning",
          "checkpoint",
          "archive session",
          "session file",
          "new session",
          "current session",
          "session-current"
        ],
        "intentPatterns": [
          "(implement|build|create|add).*?(feature|functionality|component)",
          "(fix|resolve|debug).*?(bug|issue|error)",
          "(refactor|restructure|reorganize).*?(code|codebase|architecture)",
          "multi[- ]step.*?(task|implementation|work)",
          "(start|begin|create|new).*?(session|work|implementation)",
          "(debugging|debug).*?(session|workflow)",
          "(migrate|migration).*?(code|system|database)",
          "(review|code review).*?(session|code|changes)",
          "(tdd|test[- ]driven).*?(development|session|workflow)",
          "(research|investigate|exploration).*?(session|task|work)",
          "(plan|break down|breakdown).*?(task|work|implementation)",
          "(archive|complete|finish).*?session"
        ]
      }
    },
