  "notes": {
    "enforcement_types": {
      "suggest": "Skill suggestion appears but doesn't block execution",
      "block": "Requires skill to be used before proceeding (guardrail)",
      "warn": "Shows warning but allows proceeding"
    },
    "priority_levels": {
      "critical": "Highest - Always trigger when matched (e.g., sub-agent-invocation before Task tool)",
      "high": "Important - Trigger for most matches (e.g., session-management, git-commits)",
      "medium": "Moderate - Trigger for clear matches (e.g., skill creation, framework context)",
      "low": "Optional - Trigger only for explicit matches"
    },
    "customization": {
      "keywords": "Tailored for Claude Fast project - session-based workflow, blog content, SEO",
      "intentPatterns": "Use regex for flexible user intent matching",
      "priority_rationale": "Critical: sub-agent (prevents bad delegation) | High: sessions, commits, navigation, blog | Medium: skills, archon, framework context"
    },
    "skill_overview": {
      "session-management": "Core workflow - triggers on implementation, features, bugs, refactoring, plus all 6 session types (debugging, migration, review, TDD, research)",
      "sub-agent-invocation": "Critical coordination - triggers before ANY agent/Task tool usage, parallel/sequential dispatch, handoffs, specialist routing",
      "git-commits": "Version control - triggers on commits, pushes, session completion, save work, branch operations",
      "codebase-navigation": "Exploration - triggers on finding, searching, understanding structure, directories, agents, specialists",
      "new-skills": "Meta-development - triggers on skill creation, troubleshooting, YAML configuration, system understanding",
      "documentation-research": "Library docs and skills registries - triggers on documentation requests, Context7, ctx7 CLI, skills.sh, API references, skill installation",
      "dev-browser": "Browser automation + debugging - triggers on browser, playwright, navigate, click, form, screenshot, console errors, network requests, debug, web app testing, ARIA snapshots, persistent sessions",
      "frontend-design": "Three-file design skill: SKILL.md (Anthropic creative philosophy - bold aesthetics, anti-AI-slop), dashboard-visual-hierarchy.md (research-backed attention/color guidance), design-systems-reference.md (enterprise precision craft from Linear/Stripe/Vercel patterns). Triggers on all frontend design, dashboards, admin panels, SaaS interfaces.",
      "react": "React/Next.js performance - triggers on React components, waterfalls, bundle size, re-renders, memoization, server/client components, Suspense, hydration, lazy loading, Core Web Vitals. 45+ rules across 8 priority categories from Vercel Engineering."
    }
  }
